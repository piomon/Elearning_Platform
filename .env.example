# ============================================================================
# Przykładowa konfiguracja środowiska.
#
# 1. Skopiuj ten plik do `.env`:        cp .env.example .env
# 2. Uzupełnij PRAWDZIWYMI wartościami (zwłaszcza sekcję "WYMAGANE W PRODUKCJI").
# 3. NIGDY nie commituj pliku `.env` do repozytorium (jest w .gitignore).
#
# Wygeneruj bezpieczne sekrety, np.:    openssl rand -hex 32
#
# UWAGA: gdy NODE_ENV=production, serwer API waliduje konfigurację przy starcie
# (src/config/env.ts) i NIE uruchomi się, jeśli brakuje którejkolwiek zmiennej
# oznaczonej niżej jako [PROD]. W trybie deweloperskim te zmienne są opcjonalne
# (odpowiednie moduły działają wtedy w trybie demonstracyjnym / wyłączonym).
# ============================================================================

# --- Baza danych (kontener postgres) ---------------------------------------
# Te wartości tworzą bazę w kontenerze `db` ORAZ budują DATABASE_URL dla API.
POSTGRES_USER=fizyka
POSTGRES_PASSWORD=zmien_to_na_silne_haslo
POSTGRES_DB=fizyka

# DATABASE_URL jest składany automatycznie w docker-compose z wartości powyżej:
#   postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
#
# UWAGA: jeśli POSTGRES_PASSWORD zawiera znaki specjalne URL (@ : / # %),
# automatycznie składany URL może być niepoprawny. Wtedy (albo gdy korzystasz
# z bazy zewnętrznej, poza Dockerem) ustaw poniżej pełny, poprawnie zakodowany
# DATABASE_URL — ma on pierwszeństwo przed wartością składaną automatycznie.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Uwierzytelnianie (Clerk) (WYMAGANE ZAWSZE) ----------------------------
# Klucze z Twojego konta Clerk (Dashboard -> API Keys: https://dashboard.clerk.com).
#   CLERK_SECRET_KEY       — klucz TAJNY backendu (NIGDY nie wystawiaj publicznie).
#   CLERK_PUBLISHABLE_KEY  — klucz PUBLICZNY; jest wbudowywany w build frontendu
#                            (kontener `web` pobiera go jako build-arg) i używany przez API.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Lista e-maili (po przecinku) automatycznie promowanych do roli administratora
# przy pierwszym logowaniu przez Clerk (dopasowanie do ZWERYFIKOWANEGO adresu).
# To sposób na utworzenie pierwszego admina bez hasła startowego. Opcjonalne.
ADMIN_EMAILS=admin@twoja-domena.pl

# --- Sekret sesji (WYMAGANE ZAWSZE) ----------------------------------------
# Podpisuje wewnętrzne tokeny HMAC (np. bilety startowe quizów z limitem czasu).
# To NIE jest klucz Clerk. Musi mieć co najmniej 32 znaki: `openssl rand -hex 32`.
SESSION_SECRET=zmien_to_dlugi_losowy_ciag_min_32_znaki

# --- Środowisko / logowanie ------------------------------------------------
NODE_ENV=production
# Poziom logów pino: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- Cykl życia treści przy starcie kontenera API --------------------------
# Punkt startowy (docker/api/entrypoint.sh) przy KAŻDYM starcie wykonuje kolejno:
#   1) migracje SCHEMATU (drizzle-kit migrate),
#   2) import treści z repo (scripts/data/export, tryb merge — nie usuwa danych),
#   3) migracje TREŚCI (content:migrate),
#   4) walidację treści (verify:content).
# Dzięki temu lekcje NIE znikają po wdrożeniu ani po odtworzeniu świeżej bazy.
# Każdy krok można wyłączyć, ustawiając odpowiednią zmienną na 0 (domyślnie 1).
RUN_DB_MIGRATE=1
RUN_IMPORT_ELEARNING=1
RUN_CONTENT_MIGRATE=1
RUN_VERIFY_CONTENT=1
# Gdy =1, TWARDY błąd walidacji treści (❌) PRZERYWA start kontenera.
# Domyślnie 0 — walidacja tylko ostrzega, aby nie powodować przestoju.
VERIFY_CONTENT_STRICT=0

# --- Adresy publiczne [PROD] -----------------------------------------------
# Używane w linkach e-mail, walidacji returnUrl płatności oraz CORS.
APP_URL=https://twoja-domena.pl
API_URL=https://twoja-domena.pl/api

# [PROD] Lista dozwolonych originów CORS (oddzielone przecinkami).
# Zwykle to po prostu APP_URL. Bez tego serwer nie wystartuje w produkcji.
ALLOWED_ORIGINS=https://twoja-domena.pl

# --- Cena kursu ------------------------------------------------------------
# Cena dostępu do kursu w GROSZACH (1 zł = 100 gr). Domyślnie 35,00 zł.
COURSE_PRICE_GROSZ=3500
# Stara cena (informacyjna) pokazywana z przekreśleniem. Domyślnie 199,00 zł.
COURSE_OLD_PRICE_GROSZ=19900

# --- Paynow (WYMAGANE W PRODUKCJI) [PROD] ----------------------------------
# Dane z panelu Paynow (sandbox: https://panel.sandbox.paynow.pl). Bez nich
# w produkcji płatności są niedostępne (zwracają 503). W trybie deweloperskim
# można je pominąć — wtedy działa płatność „mock”.
PAYNOW_API_KEY=
PAYNOW_SIGNATURE_KEY=
# sandbox | production
PAYNOW_ENV=sandbox
# Opcjonalne nadpisania (domyślnie dobierane wg PAYNOW_ENV):
# PAYNOW_API_URL=
# PAYNOW_RETURN_URL=
# PAYNOW_NOTIFICATION_URL=

# --- Bunny.net (hosting wideo) (WYMAGANE W PRODUKCJI) [PROD] ----------------
# Podstawowe — osadzanie odtwarzacza wideo na froncie:
BUNNY_LIBRARY_ID=
BUNNY_CDN_HOSTNAME=
# Klucze API biblioteki Bunny Stream — wymagane przez panel administratora
# (diagnostyka filmów /admin/course-debug, sprawdzanie stanu wideo).
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_READONLY_API_KEY=
# Identyfikatory kolekcji Bunny Stream dla działów kursu (opcjonalne).
BUNNY_COLLECTION_DZIAL_1=
BUNNY_COLLECTION_DZIAL_2=
BUNNY_COLLECTION_DZIAL_3=
BUNNY_COLLECTION_DZIAL_4=

# --- AI / Gemini (WYMAGANE W PRODUKCJI) [PROD] -----------------------------
# Bez klucza moduł sprawdzania zadań działa w trybie demonstracyjnym (tylko dev).
# Klucz uzyskasz w Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- E-mail / SMTP (WYMAGANE W PRODUKCJI) [PROD] ---------------------------
# Obsługa formularza kontaktowego oraz powiadomień.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# [PROD] Adres nadawcy wiadomości (From).
CONTACT_FROM_EMAIL=kontakt@twoja-domena.pl
# Adres odbiorcy zgłoszeń z formularza kontaktowego (opcjonalny).
CONTACT_EMAIL=kontakt@twoja-domena.pl

# --- Reverse proxy / SSL (tylko docker-compose.prod.yml + Traefik) ----------
# Domena, pod którą działa aplikacja (bez https://).
DOMAIN=twoja-domena.pl
# E-mail do rejestracji certyfikatu Let's Encrypt (powiadomienia o wygaśnięciu).
ACME_EMAIL=admin@twoja-domena.pl

# --- Port lokalny (tylko docker-compose.yml, dostęp z localhost) ------------
# Pod tym portem zobaczysz aplikację lokalnie: http://localhost:8080
WEB_PORT=8080
