# ============================================================================
# Przykładowa konfiguracja środowiska.
#
# 1. Skopiuj ten plik do `.env`:        cp .env.example .env
# 2. Uzupełnij PRAWDZIWYMI wartościami (zwłaszcza sekcję "WYMAGANE W PRODUKCJI").
# 3. NIGDY nie commituj pliku `.env` do repozytorium (jest w .gitignore).
#
# Wygeneruj bezpieczne sekrety, np.:    openssl rand -hex 32
#
# UWAGA: gdy NODE_ENV=production, serwer API waliduje konfigurację przy starcie
# (src/config/env.ts) i NIE uruchomi się, jeśli brakuje którejkolwiek zmiennej
# oznaczonej niżej jako [PROD]. W trybie deweloperskim te zmienne są opcjonalne
# (odpowiednie moduły działają wtedy w trybie demonstracyjnym / wyłączonym).
# ============================================================================

# --- Baza danych (kontener postgres) ---------------------------------------
# Te wartości tworzą bazę w kontenerze `db` ORAZ budują DATABASE_URL dla API.
POSTGRES_USER=fizyka
POSTGRES_PASSWORD=zmien_to_na_silne_haslo
POSTGRES_DB=fizyka

# DATABASE_URL jest składany automatycznie w docker-compose z wartości powyżej:
#   postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
# Nadpisz poniżej TYLKO jeśli używasz zewnętrznej bazy (poza Dockerem).
# [WYMAGANE] DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Sekrety aplikacji (WYMAGANE ZAWSZE) -----------------------------------
# Wygeneruj losowe, długie ciągi: `openssl rand -hex 32`
# JWT_SECRET musi mieć co najmniej 32 znaki.
JWT_SECRET=zmien_to_dlugi_losowy_ciag_min_32_znaki
SESSION_SECRET=zmien_to_inny_dlugi_losowy_ciag_min_32_znaki

# --- Środowisko / logowanie ------------------------------------------------
NODE_ENV=production
# Poziom logów pino: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- Adresy publiczne [PROD] -----------------------------------------------
# Używane w linkach e-mail, walidacji returnUrl płatności oraz CORS.
APP_URL=https://twoja-domena.pl
API_URL=https://twoja-domena.pl/api

# [PROD] Lista dozwolonych originów CORS (oddzielone przecinkami).
# Zwykle to po prostu APP_URL. Bez tego serwer nie wystartuje w produkcji.
ALLOWED_ORIGINS=https://twoja-domena.pl

# --- Cena kursu ------------------------------------------------------------
# Cena dostępu do kursu w GROSZACH (1 zł = 100 gr). Domyślnie 199,00 zł.
COURSE_PRICE_GROSZ=19900

# --- Przelewy24 (WYMAGANE W PRODUKCJI) [PROD] ------------------------------
# Dane z panelu Przelewy24. Bez nich płatności są niedostępne (a serwer
# produkcyjny nie wystartuje). W trybie deweloperskim można je pominąć —
# wtedy działa płatność „mock”.
P24_MERCHANT_ID=
P24_POS_ID=
P24_API_KEY=
P24_CRC=
# sandbox | production
P24_ENV=sandbox

# --- Bunny.net (hosting wideo) (WYMAGANE W PRODUKCJI) [PROD] ----------------
BUNNY_LIBRARY_ID=
BUNNY_CDN_HOSTNAME=

# --- AI / Gemini (WYMAGANE W PRODUKCJI) [PROD] -----------------------------
# Bez klucza moduł sprawdzania zadań działa w trybie demonstracyjnym (tylko dev).
# Klucz uzyskasz w Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- E-mail / SMTP (WYMAGANE W PRODUKCJI) [PROD] ---------------------------
# Obsługa formularza kontaktowego oraz powiadomień.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# [PROD] Adres nadawcy wiadomości (From).
CONTACT_FROM_EMAIL=kontakt@twoja-domena.pl
# Adres odbiorcy zgłoszeń z formularza kontaktowego (opcjonalny).
CONTACT_EMAIL=kontakt@twoja-domena.pl

# --- Reverse proxy / SSL (tylko docker-compose.prod.yml + Traefik) ----------
# Domena, pod którą działa aplikacja (bez https://).
DOMAIN=twoja-domena.pl
# E-mail do rejestracji certyfikatu Let's Encrypt (powiadomienia o wygaśnięciu).
ACME_EMAIL=admin@twoja-domena.pl

# --- Port lokalny (tylko docker-compose.yml, dostęp z localhost) ------------
# Pod tym portem zobaczysz aplikację lokalnie: http://localhost:8080
WEB_PORT=8080
