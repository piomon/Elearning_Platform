# ============================================================================
# Przykładowa konfiguracja środowiska.
#
# 1. Skopiuj ten plik do `.env`:        cp .env.example .env
# 2. Uzupełnij PRAWDZIWYMI wartościami (zwłaszcza sekcję "WYMAGANE").
# 3. NIGDY nie commituj pliku `.env` do repozytorium (jest w .gitignore).
#
# Wygeneruj bezpieczne sekrety, np.:    openssl rand -hex 32
# ============================================================================

# --- Baza danych (kontener postgres) ---------------------------------------
# Te wartości tworzą bazę w kontenerze `db` ORAZ budują DATABASE_URL dla API.
POSTGRES_USER=fizyka
POSTGRES_PASSWORD=zmien_to_na_silne_haslo
POSTGRES_DB=fizyka

# DATABASE_URL jest składany automatycznie w docker-compose z wartości powyżej:
#   postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
# Nadpisz poniżej TYLKO jeśli używasz zewnętrznej bazy (poza Dockerem).
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Sekrety aplikacji (WYMAGANE) ------------------------------------------
# Wygeneruj losowe, długie ciągi: `openssl rand -hex 32`
JWT_SECRET=zmien_to_dlugi_losowy_ciag_min_32_znaki
SESSION_SECRET=zmien_to_inny_dlugi_losowy_ciag_min_32_znaki

# --- Środowisko / logowanie ------------------------------------------------
NODE_ENV=production
# Poziom logów pino: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- Adresy publiczne ------------------------------------------------------
# Używane np. w linkach e-mail. W produkcji ustaw na swój pełny adres https.
APP_URL=https://twoja-domena.pl
API_URL=https://twoja-domena.pl/api

# --- Reverse proxy / SSL (tylko docker-compose.prod.yml + Traefik) ----------
# Domena, pod którą działa aplikacja (bez https://).
DOMAIN=twoja-domena.pl
# E-mail do rejestracji certyfikatu Let's Encrypt (powiadomienia o wygaśnięciu).
ACME_EMAIL=admin@twoja-domena.pl

# --- Port lokalny (tylko docker-compose.yml, dostęp z localhost) ------------
# Pod tym portem zobaczysz aplikację lokalnie: http://localhost:8080
WEB_PORT=8080

# --- AI (opcjonalne) -------------------------------------------------------
# Bez klucza moduł sprawdzania zadań działa w trybie demonstracyjnym.
# Klucz uzyskasz w Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- E-mail / SMTP (opcjonalne, dla formularza kontaktowego) ---------------
CONTACT_EMAIL=kontakt@twoja-domena.pl
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
